#include <Arduino.h>
#include <SPI.h>
#include <SD.h>
#include <arduinoFFT.h>
#include <math.h>

HardwareSerial SpectrumSerial(2);

// ---------- UART ----------
static const int TXD2 = 17;
static const int RXD2 = 16;   // nepouzito

// ---------- SD SPI ----------
static const int SD_SCK  = 18;
static const int SD_MISO = 19;
static const int SD_MOSI = 23;
static const int SD_CS   = 27;

// ---------- FFT ----------
static const uint16_t FFT_SAMPLES = 512;   // musi byt mocnina 2
static const uint8_t NUM_BANDS = 12;

double vReal[FFT_SAMPLES];
double vImag[FFT_SAMPLES];
double samplingFrequency = 22050.0;  // prepise se z WAV hlavicky

ArduinoFFT<double> FFT(vReal, vImag, FFT_SAMPLES, samplingFrequency);

// ---------- WAV info ----------
struct WavInfo {
  uint16_t audioFormat = 0;
  uint16_t numChannels = 0;
  uint32_t sampleRate = 0;
  uint16_t bitsPerSample = 0;
  uint32_t dataOffset = 0;
  uint32_t dataSize = 0;
};

File wavFile;
WavInfo wav;

uint8_t bands[NUM_BANDS];
float bandSmooth[NUM_BANDS];

bool playbackFinished = false;

// ------------------------------------------------------------

uint16_t readLE16(File &f) {
  uint8_t b0 = f.read();
  uint8_t b1 = f.read();
  return (uint16_t)(b0 | (b1 << 8));
}

uint32_t readLE32(File &f) {
  uint8_t b0 = f.read();
  uint8_t b1 = f.read();
  uint8_t b2 = f.read();
  uint8_t b3 = f.read();
  return (uint32_t)(b0 | (b1 << 8) | (b2 << 16) | (b3 << 24));
}

bool parseWavHeader(File &f, WavInfo &info) {
  f.seek(0);

  char riff[5] = {0};
  f.read((uint8_t*)riff, 4);
  if (strncmp(riff, "RIFF", 4) != 0) {
    Serial.println("Neni RIFF");
    return false;
  }

  (void)readLE32(f); // celkova delka

  char wave[5] = {0};
  f.read((uint8_t*)wave, 4);
  if (strncmp(wave, "WAVE", 4) != 0) {
    Serial.println("Neni WAVE");
    return false;
  }

  bool foundFmt = false;
  bool foundData = false;

  while (f.available()) {
    char chunkId[5] = {0};
    if (f.read((uint8_t*)chunkId, 4) != 4) break;
    uint32_t chunkSize = readLE32(f);

    if (strncmp(chunkId, "fmt ", 4) == 0) {
      info.audioFormat   = readLE16(f);
      info.numChannels   = readLE16(f);
      info.sampleRate    = readLE32(f);
      (void)readLE32(f); // byteRate
      (void)readLE16(f); // blockAlign
      info.bitsPerSample = readLE16(f);

      // preskoc pripadne dalsi fmt data
      if (chunkSize > 16) {
        f.seek(f.position() + (chunkSize - 16));
      }

      foundFmt = true;
    }
    else if (strncmp(chunkId, "data", 4) == 0) {
      info.dataOffset = f.position();
      info.dataSize   = chunkSize;
      foundData = true;
      break;
    }
    else {
      // preskoc nezname chunky
      f.seek(f.position() + chunkSize);
    }

    // WAV chunky byvaji zarovnane na sudy pocet bajtu
    if (chunkSize & 1) {
      f.seek(f.position() + 1);
    }
  }

  if (!foundFmt || !foundData) {
    Serial.println("Chybi fmt nebo data chunk");
    return false;
  }

  if (info.audioFormat != 1) {
    Serial.println("Podporuju jen PCM WAV");
    return false;
  }

  if (info.bitsPerSample != 16) {
    Serial.println("Podporuju jen 16-bit WAV");
    return false;
  }

  if (info.numChannels != 1 && info.numChannels != 2) {
    Serial.println("Podporuju jen mono/stereo WAV");
    return false;
  }

  return true;
}

String findFirstWavFile() {
  File root = SD.open("/");
  if (!root || !root.isDirectory()) {
    return "";
  }

  File entry = root.openNextFile();
  while (entry) {
    if (!entry.isDirectory()) {
      String name = entry.name();
      String lower = name;
      lower.toLowerCase();
      if (lower.endsWith(".wav")) {
        entry.close();
        return name;
      }
    }
    entry.close();
    entry = root.openNextFile();
  }

  return "";
}

void printWavInfo(const WavInfo &info) {
  Serial.println("WAV info:");
  Serial.print("  Format: "); Serial.println(info.audioFormat);
  Serial.print("  Kanaly: "); Serial.println(info.numChannels);
  Serial.print("  Sample rate: "); Serial.println(info.sampleRate);
  Serial.print("  Bits: "); Serial.println(info.bitsPerSample);
  Serial.print("  Data offset: "); Serial.println(info.dataOffset);
  Serial.print("  Data size: "); Serial.println(info.dataSize);
}

void sendFrame(const uint8_t *data, size_t len) {
  SpectrumSerial.write(0xAA);
  SpectrumSerial.write(data, len);
  SpectrumSerial.write(0x55);
}

double readNextMonoSample(File &f, const WavInfo &info, bool &ok) {
  ok = false;

  if (!f.available()) {
    return 0.0;
  }

  if (info.numChannels == 1) {
    int16_t s = (int16_t)readLE16(f);
    ok = true;
    return (double)s;
  }

  // stereo -> prumer L a R
  int16_t l = (int16_t)readLE16(f);
  int16_t r = (int16_t)readLE16(f);
  ok = true;
  return ((double)l + (double)r) * 0.5;
}

void computeBandsFromFFT() {
  // frekvence jednotlivych binu
  double binHz = samplingFrequency / FFT_SAMPLES;

  // 12 pasem, zhruba logaritmicky
  const double bandEdges[NUM_BANDS + 1] = {
    40, 80, 120, 180, 260, 380, 550, 800, 1200, 1800, 2700, 4000, 6000
  };

  for (int i = 0; i < NUM_BANDS; i++) {
    double sum = 0.0;
    int count = 0;

    int startBin = max(1, (int)(bandEdges[i] / binHz));
    int endBin   = min((int)(FFT_SAMPLES / 2 - 1), (int)(bandEdges[i + 1] / binHz));

    for (int b = startBin; b <= endBin; b++) {
      sum += vReal[b];
      count++;
    }

    double avg = (count > 0) ? (sum / count) : 0.0;

    // logaritmicke stlaceni, aby to vypadalo lepe
    double level = log10(1.0 + avg) * 90.0;

    if (level > 255.0) level = 255.0;
    if (level < 0.0) level = 0.0;

    // jemne vyhlazeni
    bandSmooth[i] = bandSmooth[i] * 0.65f + (float)level * 0.35f;
    bands[i] = (uint8_t)bandSmooth[i];
  }
}

bool fillFFTBuffer() {
  for (uint16_t i = 0; i < FFT_SAMPLES; i++) {
    bool ok = false;
    double s = readNextMonoSample(wavFile, wav, ok);

    if (!ok) {
      playbackFinished = true;
      return false;
    }

    // normalizace na cca -1 .. +1
    vReal[i] = s / 32768.0;
    vImag[i] = 0.0;
  }
  return true;
}

void processFFTFrame() {
  FFT = ArduinoFFT<double>(vReal, vImag, FFT_SAMPLES, samplingFrequency);
  FFT.windowing(FFTWindow::Hamming, FFTDirection::Forward);
  FFT.compute(FFTDirection::Forward);
  FFT.complexToMagnitude();
  computeBandsFromFFT();
  sendFrame(bands, NUM_BANDS);
}

void setup() {
  Serial.begin(115200);
  delay(800);

  SpectrumSerial.begin(115200, SERIAL_8N1, RXD2, TXD2);

  SPI.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);

  if (!SD.begin(SD_CS, SPI)) {
    Serial.println("SD init selhala");
    while (true) delay(1000);
  }

  Serial.println("SD OK");

  String wavName = findFirstWavFile();
  if (wavName.isEmpty()) {
    Serial.println("Na SD neni zadny .wav soubor");
    while (true) delay(1000);
  }

  Serial.print("Oteviram: ");
  Serial.println(wavName);

  wavFile = SD.open("/" + wavName);
  if (!wavFile) {
    Serial.println("Nepodarilo se otevrit WAV");
    while (true) delay(1000);
  }

  if (!parseWavHeader(wavFile, wav)) {
    Serial.println("Nepodporovany WAV");
    while (true) delay(1000);
  }

  printWavInfo(wav);

  samplingFrequency = (double)wav.sampleRate;
  wavFile.seek(wav.dataOffset);

  for (int i = 0; i < NUM_BANDS; i++) {
    bands[i] = 0;
    bandSmooth[i] = 0.0f;
  }

  Serial.println("Start FFT analyzy...");
}

void loop() {
  if (playbackFinished) {
    // po dokonceni zhasnout LED
    static bool sentZero = false;
    if (!sentZero) {
      memset(bands, 0, sizeof(bands));
      sendFrame(bands, NUM_BANDS);
      Serial.println("Konec souboru");
      sentZero = true;
    }
    delay(100);
    return;
  }

  if (!fillFFTBuffer()) {
    return;
  }

  processFFTFrame();

  // male zvolneni serial debug/LED
  delay(10);
}